	<Operation Class="PatchOperationFindMod">
	<mods>
		<li>Geological Landforms</li>
	</mods>
		<match Class="PatchOperationSequence">
			<success>Always</success>
			<operations>

					<li Class="PatchOperationReplace">
						<xpath>Defs/BiomeDef[defName="TemperateArchipelago"]/terrainPatchMakers</xpath>
						<value>
							<terrainPatchMakers>
								<li>
									<perlinFrequency>0.015</perlinFrequency>
									<thresholds>
										<li>
											<terrain>Gravel</terrain>
											<min>0.85</min>
											<max>999</max>
										</li>
									</thresholds>
								</li>
							</terrainPatchMakers>	
						</value>	
					</li>
							
			</operations>
		</match>
    </Operation>	

	
	
