<?xml version="1.0" encoding="UTF-8"?>
<Patch>

	<Operation Class="PatchOperationFindMod">
	<mods>
		<li>Vile's Mountains and Meadows</li>
	</mods>
	<match Class="PatchOperationSequence">
		<operations>
		
		<!-- Olive -->
		<li Class="PatchOperationReplace">
			<xpath>Defs/ThingDef[defName="Plant_TreeOlive"]/plant/growDays</xpath>
			<value>
   				<growDays>42</growDays> 
			</value>
		</li>
		<li Class="PatchOperationReplace">
			<xpath>Defs/ThingDef[defName="Plant_TreeOlive"]/plant/harvestYield</xpath>
			<value>
   				 <harvestYield>37</harvestYield> 
			</value>
		</li>
		<li Class="PatchOperationAdd">
			<xpath>Defs/ThingDef[defName="Plant_TreeOlive"]/plant</xpath>
			<value>
   				 <harvestAfterGrowth>0.50</harvestAfterGrowth>
			</value>
		</li>

		
		<!-- Cloudberry -->
		<li Class="PatchOperationReplace">
			<xpath>Defs/ThingDef[defName="Plant_Cloudberry"]/plant/growDays</xpath>
			<value>
   				<growDays>21</growDays> 
			</value>
		</li>
		<li Class="PatchOperationReplace">
			<xpath>Defs/ThingDef[defName="Plant_Cloudberry"]/plant/harvestYield</xpath>
			<value>
   				 <harvestYield>21</harvestYield> 
			</value>
		</li>
		<li Class="PatchOperationAdd">
			<xpath>Defs/ThingDef[defName="Plant_Cloudberry"]/plant</xpath>
			<value>
   				 <harvestAfterGrowth>0.3</harvestAfterGrowth>
			</value>
		</li>
		
		
		</operations>
		</match>
    </Operation>	
</Patch>	
