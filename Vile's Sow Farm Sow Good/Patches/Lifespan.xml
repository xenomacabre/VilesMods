<?xml version="1.0" encoding="UTF-8"?>
<Patch>

	<Operation Class="PatchOperationFindMod">
	<mods>
		<li>Core SK</li>
	</mods>
	<match Class="PatchOperationSequence">
		<operations>
		
		<!-- Default, I believe, is 8. Multiply this by grow time to find lifespan -->
		
		<li Class="PatchOperationAdd">
			<xpath>Defs/ThingDef[defName="Plantbean"
								or defName="PlantTomato"
								or defName="Plant_Devilstrand"
								or defName="PepperPlant"
								or defName="Plant_Psychoid"
								or defName="Plant_Watermelon"]/plant</xpath> 
			<value>
					<lifespanDaysPerGrowDays>2.5</lifespanDaysPerGrowDays>
			</value>
		</li>
		
		<li Class="PatchOperationAdd">
			<xpath>Defs/ThingDef[defName="Plant_Mushroom"]/plant</xpath>
			<value>
					<lifespanDaysPerGrowDays>4</lifespanDaysPerGrowDays>
			</value>
		</li>
		
		<li Class="PatchOperationAdd">
			<xpath>Defs/ThingDef[defName="Plant_Potato"
								or defName="Plant_Onion"
								or defName="Plant_Hypericum"
								or defName="Plant_Tea"
								or defName="Plant_NeutroFlower"]/plant</xpath> 
			<value>
					<lifespanDaysPerGrowDays>5</lifespanDaysPerGrowDays>
			</value>
		</li>
		
		<li Class="PatchOperationAdd">
			<xpath>Defs/ThingDef[defName="PlantCarrot"
								or defName="Plant_Haygrass"]/plant</xpath> <!--biannual-->
			<value>
					<lifespanDaysPerGrowDays>16</lifespanDaysPerGrowDays>
			</value>
		</li>



		</operations>
		</match>
    </Operation>	
</Patch>	
